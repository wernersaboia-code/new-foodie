generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // Conexão principal
  directUrl = env("POSTGRES_URL_NON_POOLING") // Usado para criar as tabelas sem erro
}

// 🏢 O RESTAURANTE (O nosso "Tenant" / Subdomínio)
model Restaurant {
  id          String   @id @default(cuid())
  name        String // Ex: Burger King
  subdomain   String   @unique // Ex: "burgerking" (Isso é o que o middleware vai ler!)
  description String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações (Um restaurante tem várias categorias, produtos e pedidos)
  categories Category[]
  products   Product[]
  orders     Order[]
}

// 🍔 CATEGORIAS DO CARDÁPIO (Ex: Lanches, Bebidas, Sobremesas)
model Category {
  id   String @id @default(cuid())
  name String

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())

  @@index([restaurantId])
}

// 🍟 OS PRODUTOS (Ex: Whopper Duplo)
model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isAvailable Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
}

// 🛵 OS PEDIDOS
model Order {
  id           String @id @default(cuid())
  customerName String
  status       String @default("PENDING") // PENDING, PREPARING, DELIVERED
  total        Float

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId])
}
